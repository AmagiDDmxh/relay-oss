# Optional. If omitted, the demo targets a local Relay API.
VITE_RELAY_API_URL=http://localhost:8080
# Required when VITE_RELAY_API_URL is set. Use a short-lived development key or a local mock value.
VITE_SUPPLIER_API_KEY=change-me

# Required for real device-scoped writes. Combine the per-watch X-Device-ID
# with either X-Owner-User-ID or X-App-ID to avoid stale data after device transfer.
VITE_OWNER_USER_ID=user_demo
# VITE_APP_ID=app_demo
# VITE_DEVICE_ID=device_demo_001

# Optional advanced mode. Device JWT may carry the same owner context.
# VITE_DEVICE_JWT=<signed-device-jwt>

# Optional comma-separated hosts for local/dev reverse proxies.
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
